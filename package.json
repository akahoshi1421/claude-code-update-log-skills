    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "14.26.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
