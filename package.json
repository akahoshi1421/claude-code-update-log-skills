{
  "name": "claude-code-update-log-skills",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Claude Codeのアップデートを追跡しDiscordに通知するskills集",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "check": "bash scripts/check-updates.sh",
